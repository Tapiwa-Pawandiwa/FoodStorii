# Anthropic — set in Railway dashboard
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# LangSmith — set in Railway dashboard
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-service-key-here
LANGCHAIN_PROJECT=foodstoraii-tina-prod
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Supabase — set in Railway dashboard
SUPABASE_URL=your-supabase-project-url-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_DB_URL=your-supabase-direct-postgres-url-here

# Railway Redis — auto-injected by Railway when Redis service is added
REDIS_URL=your-railway-redis-url-here

# Internal security
INTERNAL_SECRET=generate-a-random-string-here

# Config
ENVIRONMENT=production
MAX_THREAD_MESSAGES=20
CONTEXT_CACHE_TTL_SECONDS=300
SESSION_CACHE_TTL_SECONDS=3600
